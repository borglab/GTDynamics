  <link name="robot2_tool0"/>
  <!--  -->
  <!--  -->
  <!-- GLOBAL JOINTS -->
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="columns"/>
    <axis xyz="1.0 0.0 0.0"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>
  <joint name="columns_joint" type="fixed">
    <parent link="columns"/>
    <child link="x_rail"/>
    <axis xyz="1.0 0.0 0.0"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>
  <!--  -->
  <!--  -->
  <!-- BRIDGE 1 JOINTS -->
  <joint name="bridge1_joint_EA_X" type="prismatic">
    <parent link="x_rail"/>
    <child link="bridge1"/>
    <axis xyz="1.0 0.0 0.0"/>
    <dynamics damping="0.2" friction="0.0"/>
    <limit lower="0.0" upper="13.000" effort="100000.0" velocity="2.618"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>
  <joint name="robot1_joint_EA_Y" type="prismatic">
    <parent link="bridge1"/>
    <child link="robot1_xy_cart"/>
    <axis xyz="0.0 1.0 0.0"/>
    <dynamics damping="0.2" friction="0.0"/>
    <limit lower="0.0" upper="7.300" effort="100000.0" velocity="2.618"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>
  <joint name="robot1_joint_EA_Z" type="prismatic">
    <parent link="robot1_xy_cart"/>
    <child link="robot1_base"/>
